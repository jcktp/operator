/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/tests/test-data

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# claude code tooling
CLAUDE.md
AGENTS.md
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# database — all SQLite variants and WAL/SHM sidecar files
prisma/dev.db
prisma/dev.db-journal
prisma/dev.db-wal
prisma/dev.db-shm
dev.db
dev.db-journal
dev.db-wal
dev.db-shm
*.sqlite
*.sqlite3
*.db-wal
*.db-shm

# local encryption key — never commit this
prisma/.operator_key

# TLS / certificate files
*.key
*.crt
*.p12
*.pfx

# cloudflared binary (downloaded at runtime by start.sh)
cloudflared
memory/
