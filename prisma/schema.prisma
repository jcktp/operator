generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model DirectReport {
  id             String          @id @default(uuid())
  name           String
  title          String
  email          String?
  area           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  reports        Report[]
  reportRequests ReportRequest[]
}

model ReportRequest {
  id             String        @id @default(uuid())
  token          String        @unique
  title          String
  area           String
  message        String?
  directReportId String?
  directReport   DirectReport? @relation(fields: [directReportId], references: [id])
  status         String        @default("pending")
  createdAt      DateTime      @default(now())
  expiresAt      DateTime?
}

model Report {
  id             String        @id @default(uuid())
  title          String
  fileName       String
  fileType       String
  fileSize       Int
  rawContent     String
  summary        String?
  metrics        String?
  insights       String?
  questions      String?
  comparison     String?
  displayContent String?
  area           String
  reportDate     DateTime?
  resolvedFlags  String?
  directReportId String?
  directReport   DirectReport? @relation(fields: [directReportId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model JournalEntry {
  id        String   @id @default(uuid())
  weekStart DateTime
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([weekStart])
}

model DispatchChat {
  id        String   @id @default(uuid())
  title     String
  messages  String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
