generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model DirectReport {
  id             String          @id @default(uuid())
  name           String
  title          String
  email          String?
  area           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  reports        Report[]
  reportRequests ReportRequest[]
}

model ReportRequest {
  id             String        @id @default(uuid())
  token          String        @unique
  title          String
  area           String
  message        String?
  directReportId String?
  directReport   DirectReport? @relation(fields: [directReportId], references: [id])
  status         String        @default("pending")
  createdAt      DateTime      @default(now())
  expiresAt      DateTime?
}

model ReportSeries {
  id        String   @id @default(uuid())
  name      String
  area      String
  createdAt DateTime @default(now())
  reports   Report[]
}

model Report {
  id             String        @id @default(uuid())
  title          String
  fileName       String
  fileType       String
  fileSize       Int
  rawContent     String
  summary        String?
  metrics        String?
  insights       String?
  questions      String?
  comparison     String?
  displayContent String?
  area           String
  reportDate     DateTime?
  resolvedFlags  String?
  imagePath      String?
  isLongitudinal Boolean       @default(false)
  seriesId       String?
  series         ReportSeries? @relation(fields: [seriesId], references: [id])
  directReportId String?
  directReport   DirectReport? @relation(fields: [directReportId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  // Journalism back-relations
  entities       ReportEntity[]
  timelineEvents TimelineEvent[]
  journalism     ReportJournalism?

  @@index([area])
  @@index([directReportId])
  @@index([createdAt])
  @@index([area, directReportId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  detail    String?
  createdAt DateTime @default(now())
}

model PulseFeed {
  id          String      @id @default(uuid())
  name        String
  url         String
  type        String      // rss | reddit | youtube | webhook
  enabled     Boolean     @default(true)
  lastFetched DateTime?
  createdAt   DateTime    @default(now())
  items       PulseItem[]
}

model PulseItem {
  id             String    @id @default(uuid())
  feedId         String
  feed           PulseFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)
  title          String
  url            String?
  summary        String?
  publishedAt    DateTime?
  savedToJournal Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model JournalEntry {
  id        String    @id @default(uuid())
  title     String    @default("Untitled")
  folder    String    @default("General")
  content   String    @default("")
  weekStart DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model DispatchChat {
  id        String   @id @default(uuid())
  title     String
  messages  String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Journalism mode tables ────────────────────────────────────────────────────

model ReportEntity {
  id        String   @id @default(uuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  type      String   // person | organisation | location | date | financial
  name      String
  context   String?
  createdAt DateTime @default(now())

  @@index([reportId])
  @@index([name])
  @@index([type])
}

model TimelineEvent {
  id          String   @id @default(uuid())
  reportId    String
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  dateText    String
  dateSortKey String?
  event       String
  createdAt   DateTime @default(now())

  @@index([reportId])
  @@index([dateSortKey])
}

model ReportJournalism {
  id                    String   @id @default(uuid())
  reportId              String   @unique
  report                Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  redactions            String?
  journalismComparison  String?
  verificationChecklist String?
  createdAt             DateTime @default(now())
}
