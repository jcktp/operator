generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model DirectReport {
  id             String          @id @default(uuid())
  name           String
  title          String
  email          String?
  phone          String?
  area           String
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  reports        Report[]
  reportRequests ReportRequest[]
  storySources   StorySource[]
}

model ReportRequest {
  id             String        @id @default(uuid())
  token          String        @unique
  title          String
  area           String
  message        String?
  directReportId String?
  directReport   DirectReport? @relation(fields: [directReportId], references: [id])
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status         String        @default("pending")
  createdAt      DateTime      @default(now())
  expiresAt      DateTime?
}

model ReportSeries {
  id        String   @id @default(uuid())
  name      String
  area      String
  createdAt DateTime @default(now())
  reports   Report[]
}

model Project {
  id          String    @id @default(uuid())
  name        String
  area        String    @default("")
  startDate   DateTime?
  status      String    @default("in_progress") // in_progress | completed
  description String?   @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  reports        Report[]
  reportRequests ReportRequest[]
  journalEntries JournalEntry[]

  @@index([status])
  @@index([createdAt])
}

model Report {
  id             String        @id @default(uuid())
  title          String
  fileName       String
  fileType       String
  fileSize       Int
  rawContent     String
  summary        String?
  metrics        String?
  insights       String?
  questions      String?
  comparison     String?
  displayContent String?
  area           String
  reportDate     DateTime?
  resolvedFlags  String?
  imagePath      String?
  filePath       String?  // relative path within getReportsRoot(), set for uploaded (non-image) files
  storyName      String?  // kept for backwards compat; projectId is the canonical grouping
  userNotes      String?  // analyst notes visible on the report page
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  isLongitudinal Boolean       @default(false)
  seriesId       String?
  series         ReportSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  directReportId String?
  directReport   DirectReport? @relation(fields: [directReportId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  // Journalism back-relations
  entities       ReportEntity[]
  timelineEvents TimelineEvent[]
  journalism     ReportJournalism?

  @@index([area])
  @@index([projectId])
  @@index([directReportId])
  @@index([createdAt])
  @@index([area, directReportId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  detail    String?
  createdAt DateTime @default(now())
}

model PulseFeed {
  id          String      @id @default(uuid())
  name        String
  url         String
  type        String      // rss | reddit | youtube | webhook
  enabled     Boolean     @default(true)
  lastFetched DateTime?
  createdAt   DateTime    @default(now())
  items       PulseItem[]
}

model PulseItem {
  id             String    @id @default(uuid())
  feedId         String
  feed           PulseFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)
  title          String
  url            String?
  summary        String?
  publishedAt    DateTime?
  savedToJournal Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model JournalEntry {
  id        String    @id @default(uuid())
  title     String    @default("Untitled")
  folder    String    @default("General")
  content   String    @default("")
  weekStart DateTime?
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([projectId])
}

model DispatchChat {
  id        String   @id @default(uuid())
  title     String
  messages  String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Journalism mode tables ────────────────────────────────────────────────────

model ReportEntity {
  id        String   @id @default(uuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  type      String   // person | organisation | location | date | financial
  name      String
  context   String?
  createdAt DateTime @default(now())

  @@index([reportId])
  @@index([name])
  @@index([type])
}

model TimelineEvent {
  id          String   @id @default(uuid())
  reportId    String
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  dateText    String
  dateSortKey String?
  event       String
  createdAt   DateTime @default(now())

  @@index([reportId])
  @@index([dateSortKey])
}

model BrowserBookmark {
  id        String   @id @default(uuid())
  url       String
  title     String
  favicon   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model ReportJournalism {
  id                    String   @id @default(uuid())
  reportId              String   @unique
  report                Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  redactions            String?
  journalismComparison  String?
  verificationChecklist String?
  createdAt             DateTime @default(now())
}

// ── Knowledge base ────────────────────────────────────────────────────────────

model GlossaryTerm {
  id         String   @id @default(uuid())
  term       String
  definition String
  scope      String   // 'global' | 'mode:executive' | 'area:Finance' etc.
  createdAt  DateTime @default(now())

  @@unique([term, scope])
  @@index([scope])
}

model AreaBriefing {
  id          String   @id @default(uuid())
  area        String
  mode        String
  content     String
  userNotes   String?
  reportCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([area, mode])
  @@index([area])
}

// ── Storyline ─────────────────────────────────────────────────────────────────

model Story {
  id            String         @id @default(uuid())
  title         String
  description   String?        // Brief description / working hypothesis
  status        String         @default("researching")  // researching | writing | filed
  reportIds     String         // JSON array of report IDs
  narrative     String?        // AI-generated + edited narrative text
  events        String?        // JSON: ordered annotated events
  claimStatuses String?        // JSON: { claimId, status, note }[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  evidence      EvidenceItem[]
  sources       StorySource[]
}

model StorySource {
  id             String       @id @default(uuid())
  storyId        String
  story          Story        @relation(fields: [storyId], references: [id], onDelete: Cascade)
  directReportId String
  directReport   DirectReport @relation(fields: [directReportId], references: [id], onDelete: Cascade)
  tags           String       @default("[]")  // JSON string[] e.g. ["on-record","whistleblower"]
  notes          String?
  createdAt      DateTime     @default(now())

  @@unique([storyId, directReportId])
  @@index([storyId])
}

model EvidenceItem {
  id         String   @id @default(uuid())
  storyId    String
  story      Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  url        String
  title      String
  accessedAt DateTime?
  archiveUrl String?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([storyId])
}

// ── Background upload jobs ─────────────────────────────────────────────────────

model UploadJob {
  id        String          @id @default(uuid())
  status    String          @default("queued")  // queued|processing|done|error
  total     Int
  processed Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     UploadJobItem[]

  @@index([status])
  @@index([createdAt])
}

model UploadJobItem {
  id             String    @id @default(uuid())
  jobId          String
  job            UploadJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title          String
  area           String
  fileType       String
  fileName       String
  fileSizeBytes  Int
  rawContent     String    // extracted text content, ready for AI analysis
  displayContent String?   // structured display content (Excel JSON etc.)
  directReportId String?
  reportDate     String?   // ISO date string
  storyName      String?
  projectId      String?
  savedFilePath  String?   // relative path within reports folder
  status         String    @default("queued")  // queued|processing|done|error
  step           String?   // current processing step label shown to user
  reportId       String?
  error          String?
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([jobId])
  @@index([status])
}
