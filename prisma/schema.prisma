generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model DirectReport {
  id             String          @id @default(uuid())
  name           String
  title          String
  email          String?
  phone          String?
  area           String
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  reports        Report[]
  reportRequests ReportRequest[]
  storySources   StorySource[]
}

model ReportRequest {
  id             String        @id @default(uuid())
  token          String        @unique
  title          String
  area           String
  message        String?
  directReportId String?
  directReport   DirectReport? @relation(fields: [directReportId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status         String        @default("pending")
  createdAt      DateTime      @default(now())
  expiresAt      DateTime?
}

model ReportSeries {
  id        String   @id @default(uuid())
  name      String
  area      String
  createdAt DateTime @default(now())
  reports   Report[]
}

model Project {
  id          String    @id @default(uuid())
  name        String
  area        String    @default("")
  mode        String    @default("")  // app mode this project belongs to; "" = visible in all modes (legacy)
  startDate   DateTime?
  status      String    @default("in_progress") // in_progress | completed
  description String?   @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  reports        Report[]
  reportRequests ReportRequest[]
  journalEntries JournalEntry[]
  foiaRequests   FoiaRequest[]
  claims         Claim[]
  chatMessages   ChatMessage[]
  faceEmbeddings FaceEmbedding[]
  @@index([status])
  @@index([createdAt])
}

model Report {
  id             String        @id @default(uuid())
  title          String
  fileName       String
  fileType       String
  fileSize       Int
  rawContent     String
  summary        String?
  metrics        String?
  insights       String?
  questions      String?
  comparison     String?
  displayContent String?
  area           String
  mode           String    @default("")  // app mode this report belongs to; "" = visible in all modes (legacy)
  reportDate     DateTime?
  resolvedFlags  String?
  imagePath      String?
  filePath       String?  // relative path within getReportsRoot(), set for uploaded (non-image) files
  storyName      String?  // kept for backwards compat; projectId is the canonical grouping
  userNotes      String?  // analyst notes visible on the report page
  removedAt      DateTime?           // set when a peer deletes in a shared project
  removedBy      String?             // instance ID of the peer that removed it
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  isLongitudinal Boolean       @default(false)
  seriesId       String?
  series         ReportSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  directReportId String?
  directReport   DirectReport? @relation(fields: [directReportId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  // Journalism back-relations
  entities       ReportEntity[]
  timelineEvents TimelineEvent[]
  journalism     ReportJournalism?
  claims         Claim[]

  @@index([area])
  @@index([projectId])
  @@index([directReportId])
  @@index([createdAt])
  @@index([area, directReportId])
  @@index([mode])
  @@index([reportDate])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  detail    String?
  createdAt DateTime @default(now())
}

model PulseFeed {
  id          String      @id @default(uuid())
  name        String
  url         String
  type        String      // rss | reddit | youtube | webhook
  enabled     Boolean     @default(true)
  lastFetched DateTime?
  createdAt   DateTime    @default(now())
  items       PulseItem[]
}

model PulseItem {
  id             String    @id @default(uuid())
  feedId         String
  feed           PulseFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)
  title          String
  url            String?
  summary        String?
  publishedAt    DateTime?
  savedToJournal Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model JournalEntry {
  id        String    @id @default(uuid())
  title     String    @default("Untitled")
  folder    String    @default("General")
  content   String    @default("")
  mode      String    @default("")  // app mode; "" = visible in all modes (legacy)
  weekStart DateTime?
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([projectId])
  @@index([mode])
}

model DispatchChat {
  id        String   @id @default(uuid())
  title     String
  messages  String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Journalism mode tables ────────────────────────────────────────────────────

model ReportEntity {
  id        String   @id @default(uuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  type      String   // person | organisation | location | date | financial
  name      String
  context   String?
  createdAt DateTime @default(now())

  @@index([reportId])
  @@index([name])
  @@index([type])
}

model TimelineEvent {
  id          String   @id @default(uuid())
  reportId    String
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  dateText    String
  dateSortKey String?
  event       String
  createdAt   DateTime @default(now())

  @@index([reportId])
  @@index([dateSortKey])
}


model ReportJournalism {
  id                    String   @id @default(uuid())
  reportId              String   @unique
  report                Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  redactions            String?
  journalismComparison  String?
  verificationChecklist String?
  createdAt             DateTime @default(now())
}

// ── Knowledge base ────────────────────────────────────────────────────────────

model GlossaryTerm {
  id         String   @id @default(uuid())
  term       String
  definition String
  scope      String   // 'global' | 'mode:executive' | 'area:Finance' etc.
  createdAt  DateTime @default(now())

  @@unique([term, scope])
  @@index([scope])
}

model AreaBriefing {
  id          String   @id @default(uuid())
  area        String
  mode        String
  content     String
  userNotes   String?
  reportCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([area, mode])
  @@index([area])
}

// ── Storyline ─────────────────────────────────────────────────────────────────

model Story {
  id            String         @id @default(uuid())
  title         String
  description   String?        // Brief description / working hypothesis
  status        String         @default("researching")  // researching | writing | filed
  reportIds     String         // JSON array of report IDs
  narrative     String?        // AI-generated + edited narrative text
  events        String?        // JSON: ordered annotated events
  claimStatuses String?        // JSON: { claimId, status, note }[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  evidence      EvidenceItem[]
  sources       StorySource[]
}

model StorySource {
  id             String       @id @default(uuid())
  storyId        String
  story          Story        @relation(fields: [storyId], references: [id], onDelete: Cascade)
  directReportId String
  directReport   DirectReport @relation(fields: [directReportId], references: [id], onDelete: Cascade)
  tags           String       @default("[]")  // JSON string[] e.g. ["on-record","whistleblower"]
  notes          String?
  createdAt      DateTime     @default(now())

  @@unique([storyId, directReportId])
  @@index([storyId])
}

model EvidenceItem {
  id         String   @id @default(uuid())
  storyId    String
  story      Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  url        String
  title      String
  accessedAt DateTime?
  archiveUrl String?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([storyId])
}

// ── Journalism: FOIA tracker ──────────────────────────────────────────────────

model FoiaRequest {
  id          String    @id @default(uuid())
  agency      String
  subject     String
  description String?
  status      String    @default("draft")
  // status: draft | submitted | acknowledged | partial | fulfilled | denied | appealed
  filedAt     DateTime?
  dueAt       DateTime?
  receivedAt  DateTime?
  trackingNum String?
  notes       String?
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([projectId])
  @@index([createdAt])
}

// ── Journalism: Claim tracker ─────────────────────────────────────────────────

model Claim {
  id         String   @id @default(uuid())
  text       String
  source     String?
  sourceType String   @default("document")
  // sourceType: document | interview | social | official
  status     String   @default("unverified")
  // status: unverified | verified | disputed | false | needs_more
  notes      String?
  reportId   String?
  report     Report?  @relation(fields: [reportId], references: [id], onDelete: SetNull)
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([reportId])
  @@index([projectId])
  @@index([createdAt])
}

// ── Risk Register ─────────────────────────────────────────────────────────────

model Risk {
  id          String    @id @default(uuid())
  title       String
  description String?
  category    String    @default("operational")
  probability String    @default("medium")   // low/medium/high/critical
  impact      String    @default("medium")   // low/medium/high/critical
  owner       String?
  status      String    @default("open")     // open/mitigated/accepted/closed
  notes       String?
  dueAt       DateTime?
  resolvedAt  DateTime?                      // set automatically when status → closed/mitigated
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([projectId])
  @@index([createdAt])
}

// ── Decision Log ──────────────────────────────────────────────────────────────

model Decision {
  id        String    @id @default(uuid())
  title     String
  context   String?
  rationale String?
  outcome   String?
  status    String    @default("pending")    // pending/made/reversed/superseded
  madeBy    String?
  madeAt    DateTime?
  notes     String?
  projectId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([projectId])
  @@index([createdAt])
}

// ── Action Items & Blockers ───────────────────────────────────────────────────

model ActionItem {
  id          String    @id @default(uuid())
  title       String
  description String?
  kind        String    @default("action")   // action/blocker
  assignee    String?
  dueAt       DateTime?
  priority    String    @default("medium")   // low/medium/high/critical
  status      String    @default("open")     // open/in_progress/done/cancelled/deferred
  source      String?
  notes       String?
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([kind])
  @@index([projectId])
  @@index([createdAt])
}

// ── Policy Register ───────────────────────────────────────────────────────────

model PolicyRecord {
  id             String    @id @default(uuid())
  title          String
  description    String?
  owner          String?
  category       String    @default("general")
  status         String    @default("active")  // draft/active/under_review/archived
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([nextReviewAt])
}

// ── Deadline Tracker ──────────────────────────────────────────────────────────

model Deadline {
  id          String    @id @default(uuid())
  title       String
  description String?
  kind        String    @default("other")     // court/filing/limitation/review/hearing/contract/other
  dueAt       DateTime
  completedAt DateTime?
  status      String    @default("upcoming")  // upcoming/completed/missed/extended
  priority    String    @default("medium")    // low/medium/high/critical
  context     String?
  notes       String?
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([dueAt])
  @@index([projectId])
}

// ── Quote Bank ────────────────────────────────────────────────────────────────

model Quote {
  id         String   @id @default(uuid())
  text       String
  speaker    String?
  context    String?
  sourceType String   @default("interview")  // interview/survey/focus_group/document
  tags       String   @default("[]")         // JSON-encoded string[]
  reportId   String?
  projectId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
  @@index([reportId])
  @@index([createdAt])
}

// ── Themes Board ──────────────────────────────────────────────────────────────

model Theme {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("candidate")  // candidate/confirmed/rejected
  notes       String?
  projectId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([projectId])
}

// ── Headcount & Capacity Planning ─────────────────────────────────────────────

model HeadcountEntry {
  id            String    @id @default(uuid())
  role          String
  department    String
  currentCount  Int       @default(0)
  targetCount   Int       @default(0)
  openPositions Int       @default(0)
  attritionRate Float     @default(0)    // % per year, 0-100
  status        String    @default("planning")  // planning/recruiting/on_hold/filled
  targetDate    DateTime?
  hiringManager String?
  notes         String?
  projectId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([department])
  @@index([status])
  @@index([projectId])
}

// ── Peer-to-peer collaboration ────────────────────────────────────────────────

model InstanceIdentity {
  id                  String   @id
  publicKey           String
  privateKeyEncrypted String
  displayName         String
  createdAt           DateTime @default(now())
}

model Peer {
  id              String    @id
  displayName     String?
  publicKey       String
  lastSeen        DateTime?
  tunnelUrl       String?
  localUrl        String?
  discoveryMethod String?             // 'mdns' | 'remote'
  trusted         Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ProjectShare {
  projectId  String
  peerId     String
  permission String   @default("read_write")  // 'read_only' | 'read_write'
  sharedAt   DateTime @default(now())
  sharedBy   String?

  @@id([projectId, peerId])
  @@index([projectId])
  @@index([peerId])
}

model SyncState {
  projectId String
  peerId    String
  lastSync  DateTime?
  status    String    @default("idle")  // 'idle' | 'syncing' | 'error' | 'conflict'

  @@id([projectId, peerId])
  @@index([projectId])
}

model SyncConflict {
  id              String    @id @default(uuid())
  projectId       String
  tableName       String
  recordId        String
  fieldName       String
  localValue      String?
  remoteValue     String?
  localPeerId     String?
  remotePeerId    String?
  localTimestamp  DateTime?
  remoteTimestamp DateTime?
  resolved        Boolean   @default(false)
  resolution      String?               // 'kept_local' | 'kept_remote' | 'kept_both'
  resolvedAt      DateTime?
  resolvedBy      String?
  createdAt       DateTime  @default(now())

  @@index([projectId])
  @@index([resolved])
  @@index([createdAt])
}

// ── Collaboration chat ────────────────────────────────────────────────────────

model ChatMessage {
  id         String    @id @default(uuid())
  projectId  String
  threadId   String?               // null = root message; set = reply in thread
  content    String                // plain text with →[type::id::label] reference tokens
  authorId   String                // instance ID of sender
  authorName String                // display name at time of sending
  references String?               // JSON array of {type,id,label}
  editedAt   DateTime?
  deletedAt  DateTime?             // soft delete only
  syncClock  Int       @default(0) // monotonically increasing per-project; used for sync ordering
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([threadId])
  @@index([createdAt])
}

model ChatReadState {
  projectId     String
  instanceId    String    // which instance has read up to here
  lastReadAt    DateTime
  lastReadMsgId String?

  @@id([projectId, instanceId])
  @@index([projectId])
}

// ── Background upload jobs ─────────────────────────────────────────────────────

model UploadJob {
  id        String          @id @default(uuid())
  status    String          @default("queued")  // queued|processing|done|error
  total     Int
  processed Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     UploadJobItem[]

  @@index([status])
  @@index([createdAt])
}

// ── Journalism: Facial recognition embeddings ────────────────────────────────

model FaceEmbedding {
  id          String   @id @default(cuid())
  projectId   String
  documentId  String?
  imageSource String           // relative path within getReportsRoot(), or document reference
  bbox        String           // JSON: [x, y, w, h]
  embedding   String           // JSON: float[] (512 dims, ArcFace)
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model UploadJobItem {
  id             String    @id @default(uuid())
  jobId          String
  job            UploadJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title          String
  area           String
  fileType       String
  fileName       String
  fileSizeBytes  Int
  rawContent     String    // extracted text content, ready for AI analysis
  displayContent String?   // structured display content (Excel JSON etc.)
  directReportId String?
  reportDate     String?   // ISO date string
  storyName      String?
  projectId      String?
  savedFilePath  String?   // relative path within reports folder
  status         String    @default("queued")  // queued|processing|done|error
  step           String?   // current processing step label shown to user
  reportId       String?
  error          String?
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([jobId])
  @@index([status])
}
