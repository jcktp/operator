# Copy this file to .env.local and fill in any values you want to override.
# start.sh creates .env.local automatically on first run with DATABASE_URL set.
# You do not need to set anything here to run the app — all AI keys can be
# entered in Settings → AI inside the app instead.

# ── Database ─────────────────────────────────────────────────────────────────
# Auto-generated by start.sh — do not change unless you know what you are doing.
DATABASE_URL="file:./prisma/dev.db"

# ── Ollama (local AI) ────────────────────────────────────────────────────────
# Defaults shown — only set these if you changed your Ollama setup.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi4-mini
OLLAMA_VISION_MODEL=llava-phi3

# ── Cloud AI provider ────────────────────────────────────────────────────────
# These are optional — keys entered in the app's Settings page take precedence.
# Set AI_PROVIDER to use a cloud provider by default instead of Ollama.
# Values: ollama | anthropic | openai | google | groq | xai | perplexity | mistral
AI_PROVIDER=ollama

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
MISTRAL_API_KEY=

# ── Web search (Dispatch) ────────────────────────────────────────────────────
# Optional: Brave Search API key enables web search in Dispatch.
# Get a key at https://brave.com/search/api/
BRAVE_SEARCH_KEY=

# Ollama web access lets the Ollama model use built-in web search if supported.
OLLAMA_WEB_ACCESS=false

# ── Pulse — social feeds ─────────────────────────────────────────────────────
# Optional: only needed if you add Bluesky or Mastodon feeds in Pulse.
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
MASTODON_ACCESS_TOKEN=

# ── Misc ─────────────────────────────────────────────────────────────────────
# Set to true to block all outbound requests (Ollama only, no web search).
AIR_GAP_MODE=false
